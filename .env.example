# ============================================
# CONFIGURACIÓN DE TELEGRAM
# ============================================
# 1. Buscar @BotFather en Telegram → /newbot → copiar token
TELEGRAM_BOT_TOKEN=tu_token_aqui

# 2. Buscar @userinfobot en Telegram → enviar mensaje → copiar chat_id
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ============================================
# GEMINI (descripción IA opcional)
# ============================================
# Crea clave en Google AI Studio y colócala aquí
GEMINI_API_KEY=tu_clave_gemini

# ============================================
# CONFIGURACIÓN DE CÁMARA
# ============================================
# 0 = webcam principal, 1 = segunda cámara
# Para ESP32-CAM: http://192.168.1.100:81/stream
# Para RTSP: rtsp://usuario:clave@192.168.1.100:554/stream
CAMERA_SOURCE=0
